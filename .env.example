# Supabase Analytics Bot environment configuration
# Copy this file to ".env" and fill in real values.

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# LLM: any OpenAI-compatible endpoint powers the natural-language to SQL engine.
# Default below is Groq. Change these 3 vars to switch providers.
LLM_API_KEY=
# Groq:        https://api.groq.com/openai/v1
# DeepInfra:   https://api.deepinfra.com/v1/openai
# Together:    https://api.together.xyz/v1
# OpenRouter:  https://openrouter.ai/api/v1
# Ollama:      http://localhost:11434/v1
LLM_BASE_URL=https://api.groq.com/openai/v1
# Good SQL models: qwen-2.5-coder-32b (Groq) | Qwen/Qwen2.5-Coder-32B-Instruct
# Reliable Groq fallback if the above is unavailable: llama-3.3-70b-versatile
LLM_MODEL=qwen-2.5-coder-32b

# Simple mode: the primary Supabase/Postgres connection the bot reads directly.
# This is the "Blacklovers" store. Use a read-only database user.
DATA_DB_URL=postgresql://readonly_bot:password@host:5432/postgres

# Optional SECOND database: the "Reseller" store. When set, the bot answers each
# question against exactly ONE database (never combined). It auto-routes to this
# one when the question mentions "reseller"/"reselling"; otherwise it asks the
# user which database to use. Leave blank to run with a single database.
DATA_DB_URL_RESELLER=
# (Optional) override the primary/Blacklovers URL separately from DATA_DB_URL:
# DATA_DB_URL_BLACKLOVERS=postgresql://readonly_bot:password@host:5432/postgres

# Multi-tenant mode only. Leave blank if you are using npm run simple.
# This stores tenants, connected projects, encrypted credentials, and logs.
CONTROL_DB_URL=

# Multi-tenant mode only. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Safety limits applied to every client query
QUERY_ROW_LIMIT=500
QUERY_TIMEOUT_MS=15000

# Optional business glossary. Plain-English rules that map YOUR terms to how the
# data is actually stored, so the bot stops guessing. One rule per line.
# Example:
# BUSINESS_GLOSSARY=- "tracking" stage = orders with status = 'packed'.
# - Current stage of an order = to_stage of its latest order_stage_movements row.
BUSINESS_GLOSSARY=
