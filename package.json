{
  "name": "supabase-analytics-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-tenant Telegram bot that answers plain-English analytical questions over clients' Supabase databases.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "simple": "tsx watch src/simple.ts",
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/simple.js",
    "start:multi": "node dist/index.js",
    "db:init": "tsx scripts/init-db.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "grammy": "^1.30.0",
    "openai": "^6.45.0",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
